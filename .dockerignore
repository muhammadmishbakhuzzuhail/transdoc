backend/layout_venv
backend/.pytest_cache
backend/.ruff_cache
frontend/node_modules
frontend/dist
# large dev-only corpora / generated outputs
backend/corpus
backend/out
backend/out_validate
out_examples
docs/examples
**/.DS_Store
