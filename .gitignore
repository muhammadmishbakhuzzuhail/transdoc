# venv / build (match anywhere — backend/.venv, backend/layout_venv, etc.)
.venv/
layout_venv/
__pycache__/
*.egg-info/
*.pyc
build/
dist/

# pipeline outputs + caches
out/
# generated validation artifacts (regenerate via scripts/regen_validate.py)
out_validate/
.cache/
.pytest_cache/
.ruff_cache/

# models
*.pt
*.bin

# test corpus binaries — reproducible via backend/scripts/fetch_corpus.sh + make_samples.py
**/corpus/**/*.pdf
**/corpus/**/*.jpg
**/corpus/**/*.jpeg
**/corpus/**/*.png
**/corpus/**/*.tif
**/corpus/**/*.tiff
**/corpus/**/*.docx
**/corpus/**/*.odt
**/corpus/**/*.pptx
**/corpus/**/*.ppt
**/corpus/**/*.xlsx
**/corpus/**/*.doc
**/corpus/**/*.rtf

# FLORES-200 benchmark (downloaded by scripts/eval_translate.py — reproducible, not committed)
**/flores200_dataset/
**/flores200_dataset.tar.gz

# local tessdata cache (downloaded language/script packs for OCR eval)
**/.tessdata/

# keep the manifest
!**/corpus/README.md
# generated example outputs (gallery curation happens separately under docs/examples/)
out_examples/

# built React SPA bundled into the API (make build-web / Docker)
backend/src/transdoc/api/spa/
